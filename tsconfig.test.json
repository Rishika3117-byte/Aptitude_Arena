{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist-test",
        "rootDir": "./src"
    },
    "include": [
        "src/tests/**/*.ts",
        "src/react-app/utils/**/*.ts"
    ]
}